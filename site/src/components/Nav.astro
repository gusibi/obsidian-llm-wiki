---
import { useTranslations } from '../i18n/utils';

interface Props {
  page: 'home' | 'docs' | 'changelog' | '404';
  locale: string;
}

const { page, locale } = Astro.props;
const t = useTranslations(locale);
const base = locale === 'en' ? '' : `/${locale}`;
const isActive = (p: string) => page === p ? 'active' : '';

const otherLocale = locale === 'en' ? 'zh' : 'en';
const otherBase = otherLocale === 'en' ? '' : `/${otherLocale}`;
const slug = page === 'home' ? '' : page;
const switchUrl = `${otherBase}/${slug}`;
const switchLabel = otherLocale === 'zh' ? '中文' : 'EN';
---

<nav class="nav" id="nav" role="navigation">
  <div class="nav__inner">
    <a href={`${base}/`} class="nav__logo">
      <div class="nav__logo-icon">W</div>
      {t.meta.siteName}
    </a>

    <button class="nav__toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav__links" id="navLinks" role="menubar">
      <li role="none">
        <a href={`${base}/`} class={`nav__link ${isActive('home')}`} role="menuitem">{t.nav.home}</a>
      </li>
      <li role="none">
        <a href={`${base}/docs`} class={`nav__link ${isActive('docs')}`} role="menuitem">{t.nav.docs}</a>
      </li>
      <li role="none">
        <a href={`${base}/changelog`} class={`nav__link ${isActive('changelog')}`} role="menuitem">{t.nav.changelog}</a>
      </li>
      <li role="none">
        <a href={t.footer.githubUrl} class="nav__github" target="_blank" rel="noopener" role="menuitem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.605-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"/></svg>
          GitHub
        </a>
      </li>
      <li role="none">
        <a href={switchUrl} class="nav__link" hreflang={otherLocale} lang={otherLocale}>{switchLabel}</a>
      </li>
      <li role="none">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Toggle theme">&#9788;</button>
      </li>
    </ul>
  </div>
</nav>
